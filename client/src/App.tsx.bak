import { useState, useEffect } from "react";
import { Toaster } from "sonner";
import { fetch } from "@tauri-apps/plugin-http";
import "./App.css";
import Graph from "./Graph";
import Sidebar from "./Sidebar";
import Dial from "./Dial";
import { MetricsType, ServerType } from "./types";
async function getServerMetrics(ip: string): Promise<MetricsType> {
  const response = await fetch("http://" + ip + ":3000/metrics");
  const data = await response.json();
  return data as MetricsType;
}
function App() {
  const [metrics, setMetrics] = useState<Record<string, MetricsType>>({});
  const [servers, setServers] = useState<ServerType[]>([]);
  const [currentServer, setCurrentServer] = useState<ServerType>();
  useEffect(() => {
    const interval = setInterval(() => {
      servers.forEach(async (server) => {
        try {
          const data = await getServerMetrics(server.ip);
          setMetrics((prev) => ({ ...prev, [server.ip]: data }));
          console.log(data.cpu);
        } catch (e) {}
      });
    }, 100);
    return () => clearInterval(interval);
  }, [servers]);

  return (
    <div className="flex flex-row h-screen w-screen overflow-hidden">
      <Toaster
        position="top-right"
        toastOptions={{
          style: {
            background: "var(--panel-2)",
            borderColor: "var(--line)",
            color: "var(--fg)",
            fontSize: 12,
            padding: "8px 12px",
            width: "fit-content",
            minWidth: 250,
          },
          classNames: {
            description: "!text-fg-soft",
            error:
              "!bg-warn !border-warn !text-bg [&_[data-icon]>svg]:!text-bg [&_[data-description]]:!text-bg", //used ai for this
          },
          duration: 1000, //in miliseconds
        }}
      />
      <Sidebar
        servers={servers}
        setServers={setServers}
        metrics={metrics}
        currentServer={currentServer}
        setCurrentServer={setCurrentServer}
      />
      <main className="flex-none overflow-y-scroll p-6 flex flex-wrap items-start align-top content-start self-start transition-all duration-75">
        {currentServer && (
          <div key={currentServer.ip}>
            <Graph
              name="CPU"
              description="4 cores"
              metric={metrics[currentServer.ip]?.cpu ?? 0}
            />
            <Dial
              name="CPU"
              description="4 cores"
              metric={metrics[currentServer.ip]?.cpu ?? 0}
            />
          </div>
        )}
      </main>
    </div>
  );
}

export default App;
